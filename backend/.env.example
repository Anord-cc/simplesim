# Copy to .env and fill in your values

# Discord OAuth app (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:5000/auth/callback
PUBLIC_BASE_URL=http://localhost:5000

# Flask session key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_random_secret_key
SIMCONNECT_CALLSIGN=SIMCONNECT
SIMCONNECT_DEP=
SIMCONNECT_ARR=
SIMCONNECT_AIRCRAFT=
SIMCONNECT_TELEMETRY_TOKEN=
SIMBRIEF_USERNAME=
SIMBRIEF_USERID=
MCP_SERVER_NAME=SimpleSim MCP
MCP_SERVER_VERSION=1.0.0
